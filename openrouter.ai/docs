And here's the dynamic docs page (`app/docs/[...slug]/page.tsx`):

```tsx
import { readFile } from 'fs/promises'
import path from 'path'
import { compileMDX } from '@/lib/markdown'
import { notFound } from 'next/navigation'

interface Props {
  params: {
    slug: string[]
  }
}

export default async function DocsPage({ params }: Props) {
  const slug = params.slug?.join('/') || 'introduction'
  const filePath = path.join(process.cwd(), 'content', 'docs', `${slug}.md`)
  
  try {
    const source = await readFile(filePath, 'utf8')
    const { content, frontmatter } = await compileMDX(source)

    return (
      <article className="prose dark:prose-invert max-w-none">
        <h1>{frontmatter.title}</h1>
        {content}
      </article>
    )
  } catch (err) {
    return notFound()
  }
}
```

