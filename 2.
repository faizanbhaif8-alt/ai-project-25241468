from fastapi import FastAPI, UploadFile, File, Form
from fastapi.responses import FileResponse
from video_processor import VideoGenerator
import uuid
import os
from config import settings

app = FastAPI()
video_gen = VideoGenerator()

@app.post("/generate")
async def generate_video(prompt: str = Form(...)):
    job_id = str(uuid.uuid4())
    try:
        video_gen.queue_generation(job_id, prompt)
        return {"status": "queued", "job_id": job_id}
    except Exception as e:
        return {"error": str(e)}

@app.get("/status/{job_id}")
async def check_status(job_id: str):
    status = video_gen.get_status(job_id)
    return {"status": status}

@app.get("/download/{video_id}")
async def download_video(video_id: str):
    file_path = os.path.join(settings.OUTPUT_DIR, f"{video_id}.mp4")
    if os.path.exists(file_path):
        return FileResponse(file_path)
    return {"error": "File not found"}
