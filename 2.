### video_processor.py
```python
import os
import threading
from models.video_model import VideoModel
from config import settings

class VideoGenerator:
    def __init__(self):
        self.model = VideoModel()
        self.jobs = {}

    def queue_generation(self, job_id, prompt):
        self.jobs[job_id] = {"status": "processing"}
        thread = threading.Thread(
            target=self._generate_video,
            args=(job_id, prompt)
        )
        thread.start()

    def _generate_video(self, job_id, prompt):
        try:
            output_path = os.path.join(settings.OUTPUT_DIR, f"{job_id}.mp4")
            self.model.generate(prompt, output_path)
            self.jobs[job_id] = {"status": "complete", "path": output_path}
        except Exception as e:
            self.jobs[job_id] = {"status": "failed", "error": str(e)}

    def get_status(self, job_id):
        return self.jobs.get(job_id, {"error": "Job not found"})
